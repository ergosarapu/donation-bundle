{% extends '@EasyAdmin/crud/index.html.twig' %}

{% block configured_head_contents %}
    {{ parent() }}
    <style>
        .rule-scores-row {
            display: none;
        }
        .matching-payment-row:has(.match-score-badge:hover) + .rule-scores-row,
        .rule-scores-row:hover {
            display: table-row;
        }
        /* Remove border between main row and matching rows using box-shadow */
        .matching-payment-row td {
            box-shadow: inset 0 0px 0 #f8f9fa !important;
            padding-top: 0.25em;
            padding-bottom: 0.25em;
            background-color: #e8f0fe !important;
        }
    </style>
{% endblock %}

{% block table_body_row %}
    {% if entity.isAccessible %}
        {# Main entity row - use parent template logic #}
        {{ parent() }}

        {# Matching payments rows - aligned with entity columns #}
        {% if entity.instance.matchingPayments is not empty %}
            {% set sort_field_name = app.request.query.all['sort']|default({})|keys|first %}
            {% set status_colors = {
                'Pending': 'warning', 'Authorized': 'info', 'Captured': 'success',
                'Settled': 'success', 'Failed': 'danger', 'Canceled': 'secondary', 'Refunded': 'secondary'
            } %}

            {% for match in entity.instance.matchingPayments %}
                {% set match_entity = entity.newWithInstance(match.payment) %}

                <tr class="matching-payment-row bg-light">
                    {% if has_batch_actions %}<td class="batch-actions-selector"></td>{% endif %}

                    {% for field in entity.fields %}
                        {% set is_searchable = null == ea.crud.searchFields or field.property in ea.crud.searchFields %}
                        {% set match_value = attribute(match.payment, field.property, [], 'any') %}
                        
                        <td data-column="{{ field.property }}" class="{{ is_searchable ? 'searchable' }} {{ field.property == sort_field_name ? 'sorted' }} text-{{ field.textAlign }} {{ field.cssClass }}" dir="{{ ea.i18n.textDirection }}">
                            {% apply spaceless %}
                                {% if match_value is null %}
                                    {# Empty cell for null values #}
                                {% elseif match_value.timestamp is defined %}
                                    {# DateTimeInterface objects have timestamp property #}
                                    {{ match_value|date('Y-m-d H:i') }}
                                {% elseif match_value.name is defined and match_value.value is defined %}
                                    {# UnitEnum objects have name and value properties #}
                                    <span class="badge badge-{{ status_colors[match_value.name] ?? 'secondary' }}">{{ match_value.name }}</span>
                                {% elseif field.templateName == 'crud/field/money' %}
                                    <span class="text-{{ field.textAlign }} d-block">{{ (match_value / 100)|number_format(2, '.', ',') }}&nbsp;{{ match.payment.currency }}</span>
                                {% elseif match_value is iterable and match_value is not same as(match_value|default) %}
                                    {{ match_value|length }} items
                                {% else %}
                                    {{ match_value }}
                                {% endif %}
                            {% endapply %}
                        </td>
                    {% endfor %}
                    
                    <td class="actions">
                        {% set score_percent = (match.score * 100)|round %}
                        {% set badge_class = score_percent >= 90 ? 'success' : (score_percent >= 60 ? 'warning' : 'danger') %}
                        <span class="badge bg-{{ badge_class }} text-white me-2 match-score-badge" title="Match score (hover for details)" style="font-size: 0.75em; cursor: help;">{{ score_percent }}%</span>            
                        {% set reconcile_url = ea_url()
                            .setController(ea.crud.controllerFqcn)
                            .setAction('reconcile')
                            .set('pendingId', entity.instance.paymentId)
                            .set('matchingId', match.payment.paymentId)
                        %}
                        <a href="{{ reconcile_url }}" 
                           class="btn btn-primary action-reconcile"
                           title="Reconcile with this payment"
                           {% if score_percent < 90 %}
                           data-action-confirmation="true"
                           data-action-confirmation-message="⚠️ Match score is {{ score_percent }}% (below 90%). Are you sure you want to reconcile these payments?"
                           data-action-entity-name="{{ ea.crud.entityLabelInSingular|trans }}"
                           data-action-entity-id="{{ entity.primaryKeyValueAsString }}"
                           data-bs-toggle="modal"
                           data-bs-target="#modal-action-confirmation"
                           {% endif %}>
                            <i class="fa fa-link"></i> Reconcile
                        </a>
                    </td>
                </tr>
                
                {# Rule scores row #}
                {% if match.ruleScores is not empty %}
                    <tr class="rule-scores-row bg-light">
                        <td colspan="{{ entity.fields|length + (has_batch_actions ? 2 : 1) }}" class="py-1 ps-5" style="font-size: 0.85em;">
                            <span class="text-muted me-2"><strong>Rules:</strong></span>
                            {% for rule_name, rule_score in match.ruleScores %}
                                {% set rule_percent = (rule_score * 100)|round %}
                                {% set rule_badge = rule_percent >= 80 ? 'success' : (rule_percent >= 60 ? 'warning' : (rule_percent > 0 ? 'info' : 'secondary')) %}
                                <span class="badge bg-{{ rule_badge }} text-white me-1" title="{{ rule_name }}" style="font-size: 0.7em;">
                                    {{ rule_name }}: {{ rule_percent }}%
                                </span>
                            {% endfor %}
                        </td>
                    </tr>
                {% endif %}
            {% endfor %}
        {% endif %}
    {% endif %}
{% endblock table_body_row %}