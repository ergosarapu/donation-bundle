<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="ErgoSarapu\DonationBundle\SharedApplication\Query\Model\CommandStatus" table="projection_command_status">
        <id name="correlationId" type="string" column="correlation_id" length="50">
            <generator strategy="NONE"/>
        </id>
        <field name="appliedAt" type="datetime_immutable" column="applied_at" nullable="false"/>
    </entity>
</doctrine-mapping>
