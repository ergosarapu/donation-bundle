<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="ErgoSarapu\DonationBundle\BCDonations\Application\Query\Model\Donation" table="projection_donation">
        <id name="donationId" type="string" column="donation_id">
            <generator strategy="NONE"/>
        </id>
        <field name="paymentId" type="string" column="payment_id" nullable="false"/>
        <field name="amount" type="integer" column="amount" nullable="false"/>
        <field name="currency" type="string" column="currency" nullable="false"/>
        <field name="status" type="string" column="status" length="16" nullable="false" enum-type="ErgoSarapu\DonationBundle\BCDonations\Domain\Donation\DonationStatus"/>
        <field name="recurringPlanId" type="string" column="recurring_plan_id" nullable="true"/>
        <field name="campaignId" type="string" column="campaign_id" nullable="false"/>
        <field name="email" type="string" column="email" length="100" nullable="true"/>
        <field name="givenName" type="string" column="given_name" length="100" nullable="true"/>
        <field name="familyName" type="string" column="family_name" length="100" nullable="true"/>
        <field name="nationalIdCode" type="string" column="national_id_code" length="50" nullable="true"/>

        <field name="initiatedAt" type="datetime_immutable" column="initiated_at" nullable="true"/>
        <field name="acceptedAt" type="datetime_immutable" column="accepted_at" nullable="true"/>
        <field name="createdAt" type="datetime_immutable" column="created_at" nullable="false"/>
        <field name="effectiveDate" type="datetime_immutable" column="effective_date" nullable="false"/>

        <field name="updatedAt" type="datetime_immutable" column="updated_at" nullable="false"/>
        <unique-constraints>
            <unique-constraint name="UNIQ_donation_id_payment_id_recurring_plan_id" columns="donation_id,payment_id,recurring_plan_id"/>
        </unique-constraints>
    </entity>

</doctrine-mapping>
