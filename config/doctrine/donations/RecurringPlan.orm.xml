<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="ErgoSarapu\DonationBundle\BCDonations\Application\Query\Model\RecurringPlan" table="projection_recurring_plan">
        <id name="recurringPlanId" type="string" column="recurring_plan_id">
            <generator strategy="NONE"/>
        </id>
        <field name="activationDonationId" type="string" column="activation_donation_id" nullable="false"/>
        <field name="amount" type="integer" column="amount" nullable="false"/>
        <field name="cumulativeReceivedAmount" type="integer" column="cumulative_received_amount" nullable="false"/>
        <field name="currency" type="string" column="currency" nullable="false"/>
        <field name="interval" type="string" column="`interval`" nullable="false"/>
        <field name="status" type="string" column="status" length="16" nullable="false" enum-type="ErgoSarapu\DonationBundle\BCDonations\Domain\RecurringPlan\RecurringPlanStatus"/>
        <field name="createdAt" type="datetime_immutable" column="created_at" nullable="false"/>
        <field name="updatedAt" type="datetime_immutable" column="updated_at" nullable="false"/>
    </entity>

</doctrine-mapping>