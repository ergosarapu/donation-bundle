<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="ErgoSarapu\DonationBundle\BCIdentities\Application\Query\Model\Claim" table="projection_claim">
        <id name="claimId" type="string" column="claim_id" length="36">
            <generator strategy="NONE"/>
        </id>
        <field name="paymentId" type="string" column="payment_id" length="36" nullable="true"/>
        <field name="donationId" type="string" column="donation_id" length="36" nullable="true"/>
        <field name="givenName" type="string" column="given_name" length="100" nullable="true"/>
        <field name="familyName" type="string" column="family_name" length="100" nullable="true"/>
        <field name="rawName" type="string" column="raw_name" length="255" nullable="true"/>
        <field name="email" type="string" column="email" length="255" nullable="true"/>
        <field name="iban" type="string" column="iban" length="50" nullable="true"/>
        <field name="legalIdentifier" type="string" column="legal_identifier" length="20" nullable="true"/>
        <field name="inReview" type="boolean" column="in_review" nullable="false"/>
        <field name="resolved" type="boolean" column="resolved" nullable="false"/>
        <field name="reviewReason" type="string" column="review_reason" length="100" nullable="true"/>
        <field name="identityId" type="string" column="identity_id" length="36" nullable="true"/>
        <field name="createdAt" type="datetime_immutable" column="created_at" nullable="false"/>
        <field name="updatedAt" type="datetime_immutable" column="updated_at" nullable="false"/>

        <indexes>
            <index name="idx_projection_claim_in_review" columns="in_review,updated_at" />
            <index name="idx_projection_claim_payment_id" columns="payment_id" />
            <index name="idx_projection_claim_donation_id" columns="donation_id" />
        </indexes>
    </entity>
</doctrine-mapping>
