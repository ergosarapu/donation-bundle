<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="ErgoSarapu\DonationBundle\BCIdentities\Application\Query\Model\IdentityIban" table="projection_identity_iban">
        <id name="id" type="integer" column="id">
            <generator strategy="AUTO" />
        </id>
        <many-to-one field="identity" target-entity="ErgoSarapu\DonationBundle\BCIdentities\Application\Query\Model\Identity" inversed-by="ibans">
            <join-column name="identity_id" referenced-column-name="identity_id" nullable="false" on-delete="CASCADE" />
        </many-to-one>
        <field name="iban" type="string" column="iban" length="50" />

        <unique-constraints>
            <unique-constraint name="uniq_projection_identity_iban_identity_iban" columns="identity_id,iban" />
        </unique-constraints>

        <indexes>
            <index name="idx_projection_identity_iban_iban" columns="iban" />
        </indexes>
    </entity>
</doctrine-mapping>
